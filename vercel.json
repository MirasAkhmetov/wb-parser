{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/wildberries/route.ts": {
      "memory": 1024,
      "maxDuration": 300,
      "regions": ["fra1", "cdg1", "arn1"]
    },
    "app/api/wildberries/search/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "app/api/wildberries/compare/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}
